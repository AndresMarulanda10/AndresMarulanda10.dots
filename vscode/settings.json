        "copilot/claude-sonnet-4",
        "copilot/claude-sonnet-4.5",
        "copilot/gemini-2.5-pro",
        "copilot/gpt-4.1",
        "copilot/gpt-4o",
        "copilot/gpt-5",
        "copilot/gpt-5-codex",
        "copilot/grok-code-fast-1"
      ]
    }
  },
  // Claude Code: panel preferido
  "claudeCode.preferredLocation": "panel",

  // ─── Animaciones ───────────────────────────────────────────────────────────
  // Activa las animaciones de la extensión vscode-animations
  "animations.Enabled": true,

  // ─── Accesibilidad ─────────────────────────────────────────────────────────
  // Desactiva el soporte de accesibilidad (mejora performance)
  "editor.accessibilitySupport": "off",
  // Idioma para dictado por voz
  "accessibility.voice.speechLanguage": "es-MX",
  // Sonido al completar un comando en terminal
  "accessibility.signals.terminalCommandSucceeded": {
    "sound": "on"
  },
  // Sonido al deshacer ediciones
  "accessibility.signals.editsUndone": {
    "sound": "on"
  },

  // ─── Actualizaciones ───────────────────────────────────────────────────────
