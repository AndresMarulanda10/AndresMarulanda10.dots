{
  // ─── UI General ────────────────────────────────────────────────────────────
  // Oculta la titlebar nativa de macOS — la maneja custom-ui-style con hiddenInset
  "window.titleBarStyle": "custom",
  "window.customTitleBarVisibility": "never",
  // Oculta el command center (búsqueda centralizada en titlebar)
  "window.commandCenter": false,
  // Sistema de color forzado a dark
  "window.systemColorTheme": "dark",
  // Oculta el menú nativo (accesible con Alt en Windows/Linux)
  "window.menuBarVisibility": "toggle",
  // Control de layout (botones de panel) oculto
  "workbench.layoutControl.enabled": false,

  // ─── Vibrancy / Custom UI ──────────────────────────────────────────────────
  // Vibrancy Continued: opacidad 0 = completamente transparente
  "vscode_vibrancy.opacity": 0,
  "vscode_vibrancy.type": "fullscreen-ui",
  // Custom UI Style: configura la ventana Electron con titlebar tipo inset (macOS)
  // y posiciona los traffic lights (semáforos) manualmente
  "custom-ui-style.electron": {
    "titleBarStyle": "hiddenInset",
    "trafficLightPosition": {
      "x": 20,
      "y": 16
    }
  },
  // Fuente sans-serif global de la UI (no del editor)
  "custom-ui-style.font.sansSerif": "Dank Mono",
  // CSS inyectado globalmente en la UI de VS Code via custom-ui-style
  "custom-ui-style.stylesheet": {
    // Quita sombra de las notificaciones toast
    ".notification-toast": "box-shadow: none !important",
    // Quita sombra del command palette con iconos de archivo
    ".quick-input-widget.show-file-icons": "box-shadow: none !important",
    // Centra verticalmente el command palette
    ".quick-input-widget": "top: 25vh !important",
    // Oculta scrollbar dentro del command palette
    ".quick-input-list .scrollbar": "display: none",
    // Oculta los action buttons inline del command palette
    ".monaco-action-bar.quick-input-inline-action-bar": "display: none",
    // Quita sombra del widget de búsqueda (Cmd+F) y le da bordes redondeados
    ".editor-widget.find-widget": "box-shadow: none; border-radius: 4px",
    // Fondo del titlebar del command palette
    ".quick-input-titlebar": "background: #100B15 !important",
    // Oculta la línea inferior del título de los editor groups
    ".monaco-workbench .part.editor > .content .editor-group-container > .title.title-border-bottom:after": "display: none",
    // Oculta la sombra superior del scrollable (aparece al hacer scroll)
    ".monaco-scrollable-element > .shadow.top": "display: none",
    // Quita padding del título del sidebar
    ".sidebar .title-label": "padding: 0 !important",
    // Quita borde del sidebar
    ".sidebar": "border: none !important",
    // Quita el outline de focus en listas del workbench
    ".monaco-workbench .monaco-list:not(.element-focused):focus:before": "outline: none !important",
    // Quita outline de las filas enfocadas en listas
    ".monaco-list-row.focused": "outline: none !important",
    // Oculta la decoración de scroll del editor
    ".monaco-editor .scroll-decoration": "display: none",
    // Oculta los action buttons del título del editor
    ".title-actions": "display: none !important",
    // Centra el icono de archivo en el título del editor (cuando showTabs = none)
    ".title.show-file-icons .label-container .monaco-icon-label.file-icon": "justify-content: center; padding: 0 !important",
    // Quita el margin-right del icono en el título
    ".title .monaco-icon-label:after": "margin-right: 0",
    // Padding izquierdo del título del editor (espacio para los traffic lights)
    ".monaco-workbench .part.editor > .content .editor-group-container > .title > .label-container > .title-label": "padding-left: 60px",
    // Margin del icono de archivo en el título
    ".title .monaco-icon-label.file-icon": "margin: 0 60px",
    // Cursor con gradiente rosa/violeta
    ".monaco-editor .cursors-layer .cursor": "background-image: linear-gradient(135deg, #ffaffc 10%, #DA70D6 100%)",

    // ── Terminal transparente (Vibrancy en terminal integrada) ──────────────
    // Fondo del contenedor principal del terminal
    ".terminal .xterm": "background: transparent !important",
    // Fondo del viewport (área de texto) del terminal
    ".terminal .xterm-viewport": "background: transparent !important",
    // Fondo del canvas del terminal
    ".terminal .xterm-screen": "background: transparent !important",
    // Contenedor del panel de terminal
    ".panel .terminal-outer-container": "background: transparent !important",
    // ── Empty editor state (imagen personalizada) ──────────────────────────
    // Oculta el watermark de texto central (atajos de teclado)
    ".editor-group-watermark": "display: none !important",
