  "workbench.iconTheme": "material-icon-theme",
  // Activity bar arriba (en lugar de a la izquierda)
  "workbench.activityBar.location": "top",
  // Sidebar a la derecha (editor queda con más espacio a la izquierda)
  "workbench.sideBar.location": "right",
  // Sin tabs — solo se ve el archivo activo en el título
  "workbench.editor.showTabs": "none",
  // Oculta la barra de estado (abajo)
  "workbench.statusBar.visible": false,
  // Oculta los action buttons de los editores (split, close, etc.)
  "workbench.editor.editorActionsLocation": "hidden",
  // No abre ningún editor al iniciar VS Code
  "workbench.startupEditor": "none",
  // Desactiva los tips de inicio
  "workbench.tips.enabled": false,
  // Sin sticky scroll en el árbol de archivos
  "workbench.tree.enableStickyScroll": false,
  // Sin guías de indentación en el árbol
  "workbench.tree.renderIndentGuides": "none",
  // Indentación del árbol de archivos (px)
  "workbench.tree.indent": 8,
  // Oculta las etiquetas de los paneles (Terminal, Output, etc.)
  "workbench.panel.showLabels": false,
  // Temas preferidos para alto contraste y luz
  "workbench.preferredHighContrastLightColorTheme": "Default High Contrast",
  "workbench.preferredLightColorTheme": "Default High Contrast",
  // Desactiva el chat command center
  "chat.commandCenter.enabled": false,

  // ─── Personalizaciones de colores ─────────────────────────────────────────
  "workbench.colorCustomizations": {
    // Color de fondo del cursor (visible cuando el cursor es block sobre texto claro)
    "editorCursor.background": "#000000",
    // Oculta todos los marcadores del overview ruler (la regleta de la derecha)
    "editorOverviewRuler.wordHighlightStrongForeground": "#0000",
    "editorOverviewRuler.selectionHighlightForeground": "#0000",
    "editorOverviewRuler.rangeHighlightForeground": "#0000",
    "editorOverviewRuler.wordHighlightForeground": "#0000",
    "editorOverviewRuler.bracketMatchForeground": "#0000",
    "editorOverviewRuler.findMatchForeground": "#0000",
    "editorOverviewRuler.modifiedForeground": "#0000",
    "editorOverviewRuler.deletedForeground": "#0000",
    "editorOverviewRuler.warningForeground": "#0000",
    "editorOverviewRuler.addedForeground": "#0000",
    "editorOverviewRuler.errorForeground": "#0000",
    "editorOverviewRuler.infoForeground": "#0000",
    "editorOverviewRuler.border": "#0000",
    // Terminal completamente transparente (funciona con Vibrancy)
    "terminal.background": "#00000000",
    "panel.background": "#00000000",
    // Evita que VS Code pinte fondo negro sobre secuencias ANSI del prompt
    "terminal.selectionBackground": "#ffffff18",
    "terminal.inactiveSelectionBackground": "#00000000",
    // Sin ratio de contraste mínimo — VS Code por default modifica colores del terminal
    // para "mejorar legibilidad" y eso genera fondos negros sobre el prompt
    "terminal.integrated.minimumContrastRatio": 1,
    // Override para Monokai — fuerza transparencia aunque el tema defina un fondo
    "[Monokai]": {
      "terminal.background": "#00000000",
      "panel.background": "#00000000"
    },
    // Override específico para el tema Aura Dracula Spirit (Soft)
    "[Aura Dracula Spirit (Soft)]": {
      "editorSuggestWidget.selectedBackground": "#3A334B",
      "sideBar.background": "#191521"
    }
  },

  // ─── Editor — Fuente y tipografía ─────────────────────────────────────────
  // Fuente principal del editor
  "editor.fontFamily": "Dank Mono",
  "editor.fontSize": 14,
  // Activa ligaduras tipográficas (-> => !== etc.)
  "editor.fontLigatures": true,
  // Espaciado entre líneas (2.5 = muy aireado, estilo editorial)
  "editor.lineHeight": 2.5,
  // Comentarios en cursiva via TextMate rules
  "editor.tokenColorCustomizations": {
    "textMateRules": [
      {
        "scope": "comment",
        "settings": {
          "fontStyle": "italic"
        }
      }
    ]
  },

  // ─── Editor — Cursor ───────────────────────────────────────────────────────
  // Cursor tipo bloque (█)
  "editor.cursorStyle": "block",
  // Sin animación de parpadeo
  "editor.cursorBlinking": "solid",
  // Multi-cursor con Cmd (macOS) o Ctrl (Windows/Linux)
  "editor.multiCursorModifier": "ctrlCmd",

  // ─── Editor — Visual ───────────────────────────────────────────────────────
  // Sin minimap (la preview comprimida a la derecha)
  "editor.minimap.enabled": false,
  // Sin breadcrumbs (ruta de navegación encima del editor)
  "breadcrumbs.enabled": false,
  // No muestra espacios en blanco como puntos
  "editor.renderWhitespace": "none",
  // No muestra caracteres de control (↵, →, etc.)
  "editor.renderControlCharacters": false,
  // Sin sticky scroll (encabezados fijos al hacer scroll)
  "editor.stickyScroll.enabled": false,
  // No resalta el bracket matching
  "editor.matchBrackets": "never",
  // Sin resaltado de la línea activa
  "editor.renderLineHighlight": "none",
  // Sin resaltado de ocurrencias de la palabra seleccionada
  "editor.occurrencesHighlight": "off",
  // Sin resaltado de selección en otras partes del archivo
  "editor.selectionHighlight": false,
  // Scrollbars ocultas
  "editor.scrollbar.horizontal": "hidden",
  "editor.scrollbar.vertical": "hidden",
  // Sin borde del overview ruler
  "editor.overviewRulerBorder": false,
  // Oculta el cursor en el overview ruler
  "editor.hideCursorInOverviewRuler": true,
  // Nunca muestra los controles de fold (triángulos)
  "editor.showFoldingControls": "never",
  // Sin guías de indentación verticales
  "editor.guides.indentation": false,
  // Muestra decoradores de color (hex, rgb, etc.) en el editor
  "editor.colorDecorators": true,
  // Sin code lens (referencias/tests encima de funciones)
  "editor.codeLens": false,
  // No convierte texto en links clicables
  "editor.links": false,
  // Sin tooltips de parámetros al escribir funciones
  "editor.parameterHints.enabled": false,
  // Oculta el lightbulb de sugerencias rápidas
  "editor.lightbulb.enabled": "off",
  // Mantiene el hover (tooltip al pasar el mouse)
  "editor.hover.enabled": true,

  // ─── Editor — Números de línea ─────────────────────────────────────────────
  // Líneas relativas al cursor (estilo Vim)
  "editor.lineNumbers": "relative",

  // ─── Editor — Indentación y formato ───────────────────────────────────────
  "editor.tabSize": 2,
  // No autodetecta la indentación del archivo — usa siempre tabSize
  "editor.detectIndentation": false,
  // Formatea al guardar
  "editor.formatOnSave": true,
  // Formateador por defecto: Biome (más rápido que Prettier)
  "editor.defaultFormatter": "biomejs.biome",
  "notebook.defaultFormatter": "biomejs.biome",
  // No sugiere instalar Biome globalmente
  "biome.suggestInstallingGlobally": false,

  // ─── Editor — Autocompletado ───────────────────────────────────────────────
  // Sin sugerencias automáticas al escribir (solo al presionar trigger chars)
  "editor.quickSuggestions": {
    "other": "off"
  },
  // Activa sugerencias al escribir caracteres especiales (., (, etc.)
  "editor.suggestOnTriggerCharacters": true,
  // Tab completa snippets cuando hay sugerencia activa
  "editor.tabCompletion": "on",
  // Snippets aparecen primero en la lista de sugerencias
  "editor.snippetSuggestions": "top",

  // ─── Emmet ─────────────────────────────────────────────────────────────────
  // Tab expande abreviaciones Emmet
  "emmet.triggerExpansionOnTab": true,

  // ─── Archivos ──────────────────────────────────────────────────────────────
  // Guarda automáticamente después de un delay
  "files.autoSave": "afterDelay",
  // Elimina espacios al final de las líneas al guardar
  "files.trimTrailingWhitespace": true,
  // Inserta salto de línea al final del archivo al guardar
  "files.insertFinalNewline": true,

  // ─── Explorer (árbol de archivos) ──────────────────────────────────────────
  // Sin carpetas compactas (a/b/c en una sola línea)
  "explorer.compactFolders": false,
  // Sin confirmación al hacer drag & drop
  "explorer.confirmDragAndDrop": false,
  // Sin confirmación al eliminar
  "explorer.confirmDelete": false,
  // Sin badges (contadores de cambios git sobre iconos)
  "explorer.decorations.badges": false,
  // Sin flechas en el árbol (material-icon-theme las reemplaza)
  "material-icon-theme.hidesExplorerArrows": true,

  // ─── Git ───────────────────────────────────────────────────────────────────
  // Sin decoraciones de git en el editor (líneas de diff en el gutter)
  "scm.diffDecorations": "none",
  // Sin decoraciones de git en el árbol de archivos
  "git.decorations.enabled": false,
  // Fetch automático en background
  "git.autofetch": true,
  // Abre repos aunque estén en carpetas padre
  "git.openRepositoryInParentFolders": "always",

  // ─── Tailwind CSS ──────────────────────────────────────────────────────────
  // Muestra decoradores de color para clases Tailwind
  "tailwindCSS.colorDecorators": true,
  // Activa completado de clases Tailwind dentro de abreviaciones Emmet
  "tailwindCSS.emmetCompletions": true,
  // Nivel de tracing del servidor de Tailwind (verbose para debugging)
  "tailwindcss-intellisense.trace.server": "verbose",

  // ─── TypeScript / JavaScript ───────────────────────────────────────────────
  // Actualiza imports automáticamente al mover archivos
  "typescript.updateImportsOnFileMove.enabled": "always",
  "javascript.updateImportsOnFileMove.enabled": "always",

  // ─── Python ────────────────────────────────────────────────────────────────
  // Type checking estricto con Pylance
  "python.analysis.typeCheckingMode": "strict",

  // ─── Jupyter ───────────────────────────────────────────────────────────────
  // Excluye entornos venv del selector de kernels
  "jupyter.kernels.excludePythonEnvironments": ["venv"],
  // Completados extendidos del kernel Python
  "jupyter.enableExtendedPythonKernelCompletions": true,

  // ─── Docker Compose ────────────────────────────────────────────────────────
  "[dockercompose]": {
    "editor.insertSpaces": true,
    "editor.tabSize": 2,
    "editor.autoIndent": "advanced",
    "editor.quickSuggestions": {
      "other": true,
      "comments": false,
      "strings": true
    },
    "editor.defaultFormatter": "redhat.vscode-yaml"
  },

  // ─── GitHub Actions ────────────────────────────────────────────────────────
  "[github-actions-workflow]": {
    "editor.defaultFormatter": "redhat.vscode-yaml"
  },

  // ─── GitHub Copilot ────────────────────────────────────────────────────────
  // Next Edit Suggestions (NES): sugerencias predictivas de edición
  "github.copilot.nextEditSuggestions.enabled": true,
  // Thinking tool en el agente de Copilot Chat
  "github.copilot.chat.agent.thinkingTool": true,
  // Prompt alternativo GPT
  "github.copilot.chat.alternateGptPrompt.enabled": true,
  // Codesearch en Copilot Chat
  "github.copilot.chat.codesearch.enabled": true,
  // Scope selection al hacer preguntas en el chat
  "github.copilot.chat.scopeSelection": true,
  // Context7 para nuevos workspaces
  "github.copilot.chat.newWorkspace.useContext7": true,
  // Fetcher de completados
  "github.copilot.chat.completionsFetcher": "node-fetch",
  // Contexto temporal en el editor e inline chat
  "github.copilot.chat.editor.temporalContext.enabled": true,
  "github.copilot.chat.edits.temporalContext.enabled": true,
  // Code lens para generar tests
  "github.copilot.chat.generateTests.codeLens": true,
  // Contexto TypeScript inline
  "github.copilot.chat.languageContext.inline.typescript.enabled": true,

  // ─── Chat / AI ─────────────────────────────────────────────────────────────
  // Límite de requests por sesión de agente
  "chat.agent.maxRequests": 50,
  // Estilo de thinking colapsado con preview
  "chat.agent.thinkingStyle": "collapsedPreview",
  // Sesiones del agente en el panel lateral
  "chat.agentSessionsViewLocation": "view",
  // Historial en el empty state del chat
  "chat.emptyState.history.enabled": true,
  // Tool de todo list en el chat
  "chat.todoListTool.enabled": true,
  // Usa chat sessions para el cloud button
  "chat.useChatSessionsForCloudButton": true,
  // Inline chat v2
  "inlineChat.enableV2": true,
  // Notebook agent en inline chat
  "inlineChat.notebookAgent": true,
  // Autostart de servidores MCP
  "chat.mcp.autostart": "newAndOutdated",
  // Descubrimiento de servidores MCP (Claude Desktop)
  "chat.mcp.discovery.enabled": {
    "claude-desktop": true
  },
  // Aplica esta setting a todos los perfiles
  "workbench.settings.applyToAllProfiles": [
    "chat.mcp.discovery.enabled"
  ],
  // Permisos de modelos por servidor MCP
  "chat.mcp.serverSampling": {
    "Global in Code: figma": {
      "allowedModels": [
        "copilot/gpt-5-mini",
        "copilot/auto",
        "copilot/claude-haiku-4.5",
        "copilot/claude-3.5-sonnet",
        "copilot/claude-sonnet-4",
        "copilot/claude-sonnet-4.5",
        "copilot/gemini-2.5-pro",
        "copilot/gpt-4.1",
        "copilot/gpt-4o",
        "copilot/gpt-5",
        "copilot/gpt-5-codex",
        "copilot/grok-code-fast-1"
      ]
    }
  },
  // Claude Code: panel preferido
  "claudeCode.preferredLocation": "panel",

  // ─── Animaciones ───────────────────────────────────────────────────────────
  // Activa las animaciones de la extensión vscode-animations
  "animations.Enabled": true,

  // ─── Accesibilidad ─────────────────────────────────────────────────────────
  // Desactiva el soporte de accesibilidad (mejora performance)
  "editor.accessibilitySupport": "off",
  // Idioma para dictado por voz
  "accessibility.voice.speechLanguage": "es-MX",
  // Sonido al completar un comando en terminal
  "accessibility.signals.terminalCommandSucceeded": {
    "sound": "on"
  },
  // Sonido al deshacer ediciones
  "accessibility.signals.editsUndone": {
    "sound": "on"
  },

  // ─── Actualizaciones ───────────────────────────────────────────────────────
  // Sin actualizaciones automáticas
  "update.mode": "none",
  // Ignora recomendaciones de extensiones
  "extensions.ignoreRecommendations": true,

  // ─── Telemetría (desactivada) ──────────────────────────────────────────────
  "redhat.telemetry.enabled": false,
  "aws.telemetry": false,
  "amazonQ.telemetry": false,
  "aws.cloudformation.telemetry.enabled": true,
  "atlascode.rovodev.showEntitlementNotifications": false,

  // ─── Miscelánea ────────────────────────────────────────────────────────────
  // JSON Schemas vacío (placeholder para agregar esquemas custom)
  "json.schemas": [],
  // Terraform survey silenciado
  "azureTerraform.survey": {
    "surveyPromptDate": "2025-10-21T18:35:29.661Z",
    "surveyPromptIgnoredCount": 1
  }
}
